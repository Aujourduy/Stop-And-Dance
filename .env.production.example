# Stop & Dance - Production environment variables (template)
# Copy to .env.production and fill with real values.
# .env.production is gitignored (see .gitignore).

# Database
DB_PASSWORD=generate_with_openssl_rand_base64_32

# Rails secrets
SECRET_KEY_BASE=generate_with_bin_rails_secret
RAILS_MASTER_KEY=content_of_config_master_key

# Admin credentials for HTTP Basic Auth on /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=strong_password_here

# Alert email for scraping failures
ALERT_EMAIL=admin@stopand.dance

# Cloudflare Tunnel token (cloudflared container auth)
# Generated once via Cloudflare API when tunnel "stopand-dance" was created.
# Format: eyJhIjoi... (long JWT-like string)
CLOUDFLARE_TUNNEL_TOKEN=paste_tunnel_token_here

# OpenRouter API (site crawler LLM classification)
OPENROUTER_API_KEY=sk-or-v1-xxx
