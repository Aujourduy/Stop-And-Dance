<div class="container mx-auto px-4 py-8 max-w-4xl">
  <%# Header %>
  <div class="mb-8">
    <%= link_to "← Retour au profil", professeur_path(@professor), class: "link link-primary mb-4 inline-block" %>
    <h1 class="text-4xl font-script italic">Statistiques publiques</h1>
    <p class="opacity-60 text-xl mt-2"><%= @professor.nom %></p>
  </div>

  <%# Stats cards %>
  <div class="stats stats-vertical sm:stats-horizontal shadow w-full mb-8">
    <div class="stat">
      <div class="stat-title">Consultations du profil</div>
      <div class="stat-value text-primary"><%= number_with_delimiter(@professor.consultations_count) %></div>
      <div class="stat-desc">Nombre de fois que votre profil a été consulté</div>
    </div>
    <div class="stat">
      <div class="stat-title">Clics vers votre site</div>
      <div class="stat-value text-primary"><%= number_with_delimiter(@professor.clics_sortants_count) %></div>
      <div class="stat-desc">Nombre de fois que les visiteurs ont cliqué sur "Voir le site web"</div>
    </div>
  </div>

  <%# Info notice %>
  <div role="alert" class="alert alert-info mb-6">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
    <div>
      <h3 class="font-bold">À propos de ces statistiques</h3>
      <ul class="text-sm list-disc list-inside mt-1">
        <li>Ces statistiques sont publiques et accessibles à tous</li>
        <li>Elles sont mises à jour en temps réel</li>
        <li>Vous pouvez partager ce lien pour montrer votre visibilité sur Stop & Dance</li>
      </ul>
    </div>
  </div>

  <%# Share link %>
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body">
      <h3 class="card-title">Partager ce lien</h3>
      <div class="join w-full">
        <input type="text" readonly value="<%= stats_professeur_url(@professor) %>"
               class="input input-bordered join-item w-full" id="stats-url">
        <button onclick="navigator.clipboard.writeText(document.getElementById('stats-url').value); this.textContent='Copié!'; setTimeout(() => this.textContent='Copier', 2000)"
                class="btn btn-primary join-item">
          Copier
        </button>
      </div>
    </div>
  </div>
</div>
