<nav data-debug-id="navbar" class="navbar bg-neutral text-neutral-content hidden lg:flex sticky top-0 z-50" data-controller="mobile-drawer">
  <div class="navbar-start gap-4">
    <%= link_to root_path, class: "btn btn-circle bg-bordeaux hover:bg-bordeaux-dark border-none text-white font-hero text-3xl leading-none", aria: { label: "Accueil" } do %>S<% end %>
    <button data-action="click->mobile-drawer#toggle" class="btn btn-circle bg-terracotta hover:bg-terracotta border-none text-white text-xl" aria-label="Open navigation menu">
      <i class="fa-solid fa-bars"></i>
    </button>
    <%= link_to evenements_path, class: "btn btn-circle bg-moutarde hover:bg-moutarde border-none text-white text-xl", aria: { label: "Agenda" } do %>
      <i class="fa-regular fa-calendar"></i>
    <% end %>
    <%= link_to actualites_path, class: "btn btn-circle bg-green-600 hover:bg-green-700 border-none text-white text-xl", aria: { label: "Actualités" } do %>
      <i class="fa-regular fa-newspaper"></i>
    <% end %>
  </div>

  <div class="navbar-center">
    <span class="badge bg-moutarde text-black font-semibold px-4 py-4 text-xl">Beta publique — aidez-moi à construire l'agenda</span>
  </div>

  <div class="navbar-end">
    <%= link_to "Signaler une erreur", contact_form_url, target: "_blank", rel: "noopener", class: "btn btn-sm btn-error text-white" %>
  </div>

  <%# Drawer overlay %>
  <div data-mobile-drawer-target="overlay" class="hidden fixed inset-0 bg-black/50 z-40" data-action="click->mobile-drawer#close" aria-hidden="true"></div>

  <%# Drawer panel %>
  <aside data-mobile-drawer-target="panel" class="hidden fixed top-14 left-0 h-auto w-64 bg-neutral text-neutral-content z-50 p-6 transform transition-transform rounded-r-lg shadow-lg" aria-hidden="true">
    <button data-action="click->mobile-drawer#close" class="absolute top-4 right-4 text-2xl" aria-label="Close navigation menu">×</button>

    <ul class="menu">
      <li><%= link_to "Accueil", root_path %></li>
      <li><%= link_to "Agenda", evenements_path %></li>
      <li><%= link_to "S'inscrire à la newsletter", "#" %></li>
      <li><%= link_to "Liens", "#" %></li>
      <li><%= link_to "Les proposants", proposants_path %></li>
      <li><%= link_to "Qui suis-je", about_path %></li>
      <li><%= link_to "Faire un don", donation_path %></li>
      <li><%= link_to "Signaler une erreur", contact_form_url, target: "_blank", rel: "noopener" %></li>
      <li><%= link_to "Admin", admin_root_path %></li>
    </ul>
  </aside>
</nav>
