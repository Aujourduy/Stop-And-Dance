<div class="space-y-6 sticky top-4">
  <div data-debug-id="filters" class="card bg-base-100 shadow-sm">
    <div class="card-body p-6">

    <%# Filter header %>
    <div class="flex items-center justify-between mb-4 bg-primary text-primary-content -mx-6 -mt-6 px-6 py-4 rounded-t-box">
      <h2 class="card-title font-script italic text-2xl">Filtrez l'agenda</h2>
      <button data-action="click->mobile-filters#close"
              class="lg:hidden btn btn-ghost btn-sm text-2xl">
        &times;
      </button>
    </div>

    <%= form_with url: evenements_path,
                  method: :get,
                  format: :turbo_stream,
                  data: { controller: "auto-submit" },
                  class: "space-y-6" do |f| %>

      <%# Search field %>
      <div>
        <h3 class="font-medium mb-3">Recherche</h3>
        <%= f.text_field :q,
                         value: params[:q],
                         class: "input input-bordered w-full",
                         placeholder: "Ex: marc rennes",
                         data: { action: "change->auto-submit#submit" } %>
      </div>

      <%# Type & Format filters %>
      <div>
        <h3 class="font-medium mb-3">Type et format</h3>
        <div class="space-y-2">
          <label class="flex items-center gap-2 cursor-pointer">
            <%= f.check_box :en_presentiel,
                            { checked: params[:en_presentiel] == "true", class: "checkbox checkbox-primary checkbox-sm", data: { action: "change->auto-submit#submit" } },
                            "true", nil %>
            <span>En présentiel</span>
          </label>

          <label class="flex items-center gap-2 cursor-pointer">
            <%= f.check_box :stage,
                            { checked: params[:stage] == "true", class: "checkbox checkbox-primary checkbox-sm", data: { action: "change->auto-submit#submit" } },
                            "true", nil %>
            <span>Stage</span>
          </label>

          <label class="flex items-center gap-2 cursor-pointer">
            <%= f.check_box :en_ligne,
                            { checked: params[:en_ligne] == "true", class: "checkbox checkbox-primary checkbox-sm", data: { action: "change->auto-submit#submit" } },
                            "true", nil %>
            <span>En ligne</span>
          </label>

          <label class="flex items-center gap-2 cursor-pointer">
            <%= f.check_box :gratuit,
                            { checked: params[:gratuit] == "true", class: "checkbox checkbox-primary checkbox-sm", data: { action: "change->auto-submit#submit" } },
                            "true", nil %>
            <span>Gratuit</span>
          </label>

          <label class="flex items-center gap-2 cursor-pointer">
            <%= f.check_box :atelier,
                            { checked: params[:atelier] == "true", class: "checkbox checkbox-primary checkbox-sm", data: { action: "change->auto-submit#submit" } },
                            "true", nil %>
            <span>Atelier</span>
          </label>
        </div>
      </div>

      <%# Date filter %>
      <div>
        <h3 class="font-medium mb-3">Date</h3>
        <%= f.label :date_debut, "À partir du", class: "label" %>
        <%= f.date_field :date_debut,
                         value: params[:date_debut],
                         class: "input input-bordered w-full",
                         placeholder: "JJ/MM/AAAA",
                         data: { action: "change->auto-submit#submit" } %>
        <%# NB: change-> est correct ici, un date picker renvoie une valeur complète en une fois %>
      </div>

      <%# Geographic filter %>
      <div>
        <h3 class="font-medium mb-3">Lieu</h3>
        <%= f.label :lieu, "Adresse, ville...", class: "label" %>
        <%= f.text_field :lieu,
                         value: params[:lieu],
                         class: "input input-bordered w-full mb-3",
                         placeholder: "Paris, Lyon...",
                         data: { action: "change->auto-submit#submit" } %>

        <%= f.label :distance, "Distance (km)", class: "label" %>
        <%= f.number_field :distance,
                           class: "input input-bordered w-full",
                           placeholder: "Ex: 20",
                           disabled: true %>
        <p class="text-xs opacity-50 mt-1">Géolocalisation disponible prochainement</p>
      </div>
    <% end %>
    </div>
  </div>
</div>
