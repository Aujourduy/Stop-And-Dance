<button type="button"
        data-controller="scroll-top"
        data-action="click->scroll-top#top"
        data-debug-id="scroll-top"
        aria-label="Remonter en haut de la page"
        class="fixed bottom-5 right-5 z-40 w-12 h-12 rounded-full bg-bordeaux hover:bg-bordeaux-dark text-white shadow-lg flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-200">
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"/>
  </svg>
</button>
