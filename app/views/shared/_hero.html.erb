<section data-debug-id="hero" class="hero min-h-screen lg:min-h-[600px] bg-neutral text-neutral-content">
  <div class="hero-content text-center">
    <div class="max-w-3xl">
      <h1 class="font-hero text-primary text-5xl md:text-7xl mb-6">Stop & Dance</h1>
      <p class="text-xl md:text-2xl italic">
        Agenda de référence des pratiques de danse exploratoires et non-performatives en France.
        "Quel atelier ce soir à Paris ?" — ce que Google et Facebook ne savent pas faire.
      </p>

      <% stats = Setting.instance %>
      <% if stats.stats_updated_at.present? %>
        <p class="text-sm md:text-base opacity-70 mt-6">
          Cette semaine : <strong class="text-primary"><%= stats.stats_visits_7d.to_i %> visites</strong>
          de <strong class="text-primary"><%= stats.stats_visitors_7d.to_i %> visiteurs</strong>
        </p>
      <% end %>
    </div>
  </div>
</section>
