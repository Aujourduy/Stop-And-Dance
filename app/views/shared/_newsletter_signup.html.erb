<div data-debug-id="newsletter-signup" class="card bg-primary text-primary-content">
  <div class="card-body">
    <h2 class="card-title font-script italic text-2xl">S'inscrire à la newsletter</h2>

    <%= form_with model: Newsletter.new,
                  url: newsletters_path,
                  method: :post,
                  class: "space-y-3" do |f| %>

      <%= f.label :email, "Votre email", class: "label" %>
      <%= f.email_field :email,
                        placeholder: "votre@email.com",
                        required: true,
                        class: "input input-bordered w-full text-base-content" %>

      <%= f.submit "Souscrire",
                   class: "btn btn-neutral w-full" %>

      <p class="text-xs opacity-75 mt-2">En souscrivant, vous acceptez de recevoir nos emails (RGPD compliant).</p>
    <% end %>
  </div>
</div>
