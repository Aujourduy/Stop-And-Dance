<div class="lg:hidden" data-controller="mobile-drawer">
  <%# Mobile header %>
  <header class="navbar bg-neutral text-neutral-content sticky top-0 z-50">
    <div class="navbar-start gap-2">
      <%= link_to root_path, class: "flex items-center gap-1" do %>
        <%= image_tag "logo/favicon.ico", alt: "Stop & Dance", class: "h-6 w-6" %>
        <span class="bg-moutarde text-black font-bold text-[9px] px-1 py-px leading-none rounded">BETA</span>
      <% end %>
      <button data-action="click->mobile-drawer#toggle" class="btn btn-circle btn-primary btn-sm" aria-label="Open navigation menu">
        ☰
      </button>
      <%= link_to evenements_path, class: "flex items-center" do %>
        <%= image_tag "figma/Group 4.svg", alt: "Agenda", class: "h-6 w-auto" %>
      <% end %>
      <%= link_to actualites_path, class: "flex items-center" do %>
        <%= image_tag "figma/Group 5.svg", alt: "Actualités", class: "h-6 w-auto" %>
      <% end %>
    </div>
    <div class="navbar-end">
      <%= link_to "Signaler", contact_form_url, target: "_blank", rel: "noopener", class: "btn btn-xs btn-error text-white" %>
    </div>
  </header>

  <%# Beta banner mobile — statique, disparaît au scroll %>
  <div class="bg-moutarde text-black text-center text-xs font-semibold py-1.5 px-3 leading-snug">
    Beta publique — aidez-moi à construire l'agenda
  </div>

  <%# Drawer overlay %>
  <div data-mobile-drawer-target="overlay" class="hidden fixed inset-0 bg-black/50 z-40" data-action="click->mobile-drawer#close" aria-hidden="true"></div>

  <%# Drawer panel %>
  <aside data-mobile-drawer-target="panel" class="hidden fixed top-14 left-0 h-auto w-64 bg-neutral text-neutral-content z-50 p-6 transform transition-transform rounded-r-lg shadow-lg" aria-hidden="true">
    <button data-action="click->mobile-drawer#close" class="absolute top-4 right-4 text-2xl" aria-label="Close navigation menu">×</button>

    <ul class="menu">
      <li><%= link_to "Accueil", root_path %></li>
      <li><%= link_to "Agenda", evenements_path %></li>
      <li><%= link_to "S'inscrire à la newsletter", "#" %></li>
      <li><%= link_to "Liens", "#" %></li>
      <li><%= link_to "Les proposants", proposants_path %></li>
      <li><%= link_to "Signaler une erreur", contact_form_url, target: "_blank", rel: "noopener" %></li>
      <li><%= link_to "Admin", admin_root_path %></li>
    </ul>
  </aside>
</div>
