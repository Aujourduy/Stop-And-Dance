<h1 class="text-3xl font-bold mb-2">Professeurs</h1>
<p class="text-sm opacity-60 mb-6">Gérer et vérifier les professeurs détectés automatiquement</p>

<% if @pending_review_count > 0 %>
  <div role="alert" class="alert alert-warning mb-6">
    <span><strong><%= @pending_review_count %> professeur(s)</strong> en attente de vérification.
    <%= link_to "Voir →", admin_professors_path(status: "auto"), class: "link" %></span>
  </div>
<% end %>

<div class="mb-4 flex flex-wrap gap-2 items-end">
  <%= link_to "Tous", admin_professors_path, class: "btn btn-sm #{params[:status].nil? && params[:q].blank? ? 'btn-primary' : 'btn-ghost'}" %>
  <%= link_to "À vérifier (auto)", admin_professors_path(status: "auto"), class: "btn btn-sm #{params[:status] == 'auto' ? 'btn-primary' : 'btn-ghost'}" %>

  <%= form_with url: admin_professors_path, method: :get, class: "flex gap-2 items-center ml-auto" do |f| %>
    <%= f.hidden_field :status, value: params[:status] %>
    <%= f.text_field :q, value: params[:q], placeholder: "Rechercher un prof...", class: "input input-bordered input-sm w-48" %>
    <%= f.submit "Chercher", class: "btn btn-primary btn-sm" %>
    <% if params[:q].present? %>
      <%= link_to "×", admin_professors_path(status: params[:status]), class: "btn btn-ghost btn-sm" %>
    <% end %>
  <% end %>
</div>

<div class="overflow-x-auto">
  <table class="table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Photo</th>
        <th>Prénom</th>
        <th>Nom</th>
        <th>Status</th>
        <th>Email</th>
        <th>Site web</th>
        <th>Événements</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @professors.each do |professor| %>
        <tr class="hover <%= 'bg-warning/10' if professor.status == 'auto' %>">
          <td><%= professor.id %></td>
          <td>
            <% if professor.avatar_url.present? %>
              <%= image_tag professor.avatar_url, alt: professor.nom, class: "w-10 h-10 rounded-full object-cover", loading: "lazy" %>
            <% else %>
              <div class="avatar placeholder">
                <div class="bg-primary/30 text-primary-content w-10 h-10 rounded-full">
                  <span><%= professor.nom&.first&.upcase || "?" %></span>
                </div>
              </div>
            <% end %>
          </td>
          <td><%= professor.prenom %></td>
          <td class="font-medium"><%= professor.nom %></td>
          <td>
            <% if professor.status == "auto" %>
              <span class="badge badge-warning badge-sm">Auto</span>
            <% elsif professor.status == "reviewed" %>
              <span class="badge badge-success badge-sm">Vérifié</span>
            <% else %>
              <span class="badge badge-ghost badge-sm"><%= professor.status %></span>
            <% end %>
          </td>
          <td class="text-sm"><%= professor.email.presence || "—" %></td>
          <td class="text-sm">
            <% if professor.site_web.present? %>
              <%= link_to professor.site_web.truncate(30), professor.site_web, target: "_blank", class: "link link-primary" %>
            <% else %>
              —
            <% end %>
          </td>
          <td><%= professor.events.count %></td>
          <td class="space-x-1">
            <%= link_to "Éditer", edit_admin_professor_path(professor), class: "btn btn-ghost btn-xs" %>
            <% if professor.status == "auto" %>
              <%= button_to "Vérifier", mark_reviewed_admin_professor_path(professor), method: :post, class: "btn btn-success btn-xs" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
