<h1 class="text-3xl font-bold mb-6">Éditer le professeur</h1>

<% if @professor.status == "auto" %>
  <div role="alert" class="alert alert-warning mb-6">
    <span><strong>Professeur créé automatiquement</strong> — Vérifiez et complétez les informations</span>
  </div>
<% end %>

<div class="card bg-base-100 shadow-sm">
  <div class="card-body">
    <%= form_with model: @professor, url: admin_professor_path(@professor), method: :patch, local: true, multipart: true, class: "space-y-6" do |form| %>
      <% if @professor.errors.any? %>
        <div role="alert" class="alert alert-error">
          <ul class="list-disc list-inside">
            <% @professor.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= form.label :prenom, "Prénom", class: "label font-bold" %>
          <%= form.text_field :prenom, class: "input input-bordered w-full", placeholder: "Ex: Sophie" %>
        </div>
        <div>
          <%= form.label :nom, "Nom de famille *", class: "label font-bold" %>
          <%= form.text_field :nom, class: "input input-bordered w-full", placeholder: "Ex: Marchand", required: true %>
        </div>
      </div>

      <div>
        <%= form.label :email, "Email", class: "label font-bold" %>
        <%= form.email_field :email, class: "input input-bordered w-full", placeholder: "contact@example.com" %>
      </div>

      <div>
        <%= form.label :site_web, "Site web", class: "label font-bold" %>
        <%= form.url_field :site_web, class: "input input-bordered w-full", placeholder: "https://..." %>
      </div>

      <div data-controller="avatar-cropper"
           data-avatar-cropper-size-value="300">
        <%= form.label :photo, "Photo (upload)", class: "label font-bold" %>
        <% if @professor.avatar_url.present? %>
          <div class="flex items-center gap-4 mb-3">
            <div class="avatar">
              <div class="w-32 rounded">
                <img src="<%= @professor.avatar_url %>" alt="Avatar">
              </div>
            </div>
            <span class="text-sm opacity-60">Photo actuelle (300×300)</span>
          </div>
        <% end %>
        <%= form.file_field :photo,
                            accept: "image/*",
                            class: "file-input file-input-bordered w-full",
                            data: {
                              avatar_cropper_target: "input",
                              action: "change->avatar-cropper#fileSelected"
                            } %>
        <p class="text-sm opacity-60 mt-1">
          Choisis ton fichier puis ajuste la zone à cropper. Un aperçu 300×300 apparaît à droite.
        </p>

        <div class="mt-4 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-start">
          <div data-avatar-cropper-target="container" class="hidden border rounded bg-base-100"></div>
          <div>
            <p class="text-sm font-bold mb-1">Aperçu 300×300</p>
            <canvas data-avatar-cropper-target="preview"
                    class="border rounded bg-base-100"
                    width="300" height="300"
                    style="width: 200px; height: 200px;"></canvas>
          </div>
        </div>
      </div>

      <div>
        <%= form.label :bio, "Biographie", class: "label font-bold" %>
        <%= form.text_area :bio, rows: 4, class: "textarea textarea-bordered w-full", placeholder: "Parcours et spécialités du professeur..." %>
        <p class="text-sm opacity-60 mt-1">Visible sur la page publique du professeur.</p>
      </div>

      <div class="bg-base-200 p-4 rounded-box">
        <h3 class="font-bold mb-2">Informations système</h3>
        <div class="grid grid-cols-2 gap-2 text-sm opacity-70">
          <div><strong>ID:</strong> <%= @professor.id %></div>
          <div><strong>Nom normalisé:</strong> <%= @professor.nom_normalise %></div>
          <div><strong>Status:</strong> <%= @professor.status %></div>
          <div><strong>Événements:</strong> <%= @professor.events.count %></div>
          <div><strong>Consultations:</strong> <%= @professor.consultations_count %></div>
          <div><strong>Clics sortants:</strong> <%= @professor.clics_sortants_count %></div>
        </div>
      </div>

      <div class="flex flex-wrap gap-4">
        <%= form.submit "Enregistrer", class: "btn btn-primary" %>
        <%= link_to "Annuler", admin_professors_path, class: "btn btn-ghost" %>
        <% if @professor.status == "auto" %>
          <%= button_to "Marquer vérifié", mark_reviewed_admin_professor_path(@professor), method: :post, class: "btn btn-success ml-auto" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
