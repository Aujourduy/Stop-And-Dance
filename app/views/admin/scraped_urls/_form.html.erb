<%= form_with model: [:admin, scraped_url], class: "space-y-6", multipart: true, data: { turbo: false } do |f| %>
  <% if scraped_url.errors.any? %>
    <div role="alert" class="alert alert-error">
      <ul class="list-disc list-inside">
        <% scraped_url.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :url, "URL à scraper (technique)", class: "label font-bold" %>
    <%= f.url_field :url, class: "input input-bordered w-full", placeholder: "https://example.com/agenda", required: true %>
    <p class="text-sm opacity-60 mt-1">
      L'URL d'où on récupère les événements. Peut être une API JSON (ex: bsport.io).
    </p>
  </div>

  <div>
    <%= f.label :public_url, "URL publique (optionnel)", class: "label font-bold" %>
    <%= f.url_field :public_url, class: "input input-bordered w-full", placeholder: "https://example.com (site vitrine)" %>
    <p class="text-sm opacity-60 mt-1">
      À remplir UNIQUEMENT si l'URL à scraper ci-dessus est une API ou un endpoint technique.
      Cette URL sera affichée à l'utilisateur sous "Voir la page source" dans la modal d'un event.
    </p>
  </div>

  <div>
    <%= f.label :nom, "Nom (label descriptif)", class: "label font-bold" %>
    <%= f.text_field :nom, class: "input input-bordered w-full", placeholder: "Ex: Agenda Danse Contact Paris" %>
    <p class="text-sm opacity-60 mt-1">Nom lisible pour identifier facilement cette source dans l'admin.</p>
  </div>

  <div class="card bg-base-200 p-4">
    <h3 class="font-bold mb-2">Avatar (affiché sur l'agenda)</h3>
    <p class="text-sm opacity-60 mb-3">
      Photo affichée sur les cards de l'agenda pour identifier la source.
      <strong>Prof solo</strong> : photo du prof.
      <strong>Collectif</strong> : logo du collectif.
    </p>

    <% if scraped_url.avatar_url.present? %>
      <div class="flex items-center gap-4 mb-4">
        <%= image_tag scraped_url.avatar_url, class: "w-32 h-32 object-cover rounded", alt: "Aperçu" %>
        <span class="text-sm opacity-60">Avatar actuel (300×300)</span>
      </div>
    <% end %>

    <div class="mb-4" data-controller="avatar-cropper"
         data-avatar-cropper-size-value="300">
      <%= f.label :avatar_file, "Upload d'un fichier (prioritaire sur l'URL)", class: "label font-bold" %>
      <%= f.file_field :avatar_file,
                       accept: "image/*",
                       class: "file-input file-input-bordered w-full",
                       data: {
                         avatar_cropper_target: "input",
                         action: "change->avatar-cropper#fileSelected"
                       } %>
      <p class="text-sm opacity-60 mt-1">
        Choisis ton fichier puis ajuste la zone à cropper (carré). Un aperçu
        300×300 apparaît à droite.
      </p>

      <div class="mt-4 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-start">
        <div data-avatar-cropper-target="container" class="hidden border rounded bg-base-100"></div>
        <div>
          <p class="text-sm font-bold mb-1">Aperçu 300×300</p>
          <canvas data-avatar-cropper-target="preview"
                  class="border rounded bg-base-100"
                  width="300" height="300"
                  style="width: 200px; height: 200px;"></canvas>
        </div>
      </div>
    </div>

    <div>
      <%= f.label :avatar_url, "…ou coller une URL externe", class: "label font-bold" %>
      <%# text_field plutôt que url_field : accepte aussi les chemins locaux
          (/avatars/...) générés par ScrapedUrlAvatarService sans déclencher
          la validation HTML5 "url" qui bloquerait le submit. %>
      <%= f.text_field :avatar_url, class: "input input-bordered w-full", placeholder: "https://.../logo.png ou photo du prof" %>
    </div>
  </div>

  <div>
    <%= f.label :statut_scraping, "Statut", class: "label font-bold" %>
    <%= f.select :statut_scraping,
                 [['Actif', 'actif'], ['Pause', 'pause'], ['Erreur', 'erreur']],
                 {},
                 class: "select select-bordered w-full" %>
  </div>

  <div>
    <%= f.label :use_browser, "Mode scraping (production)", class: "label font-bold" %>
    <div class="space-y-3">
      <label class="card card-bordered cursor-pointer p-4 <%= scraped_url.use_browser == false ? 'border-success bg-success/10' : '' %>">
        <div class="flex items-start gap-3">
          <%= f.radio_button :use_browser, false, class: "radio radio-success mt-1" %>
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="font-bold">HTTParty</span>
              <span class="badge badge-success badge-sm">Rapide</span>
            </div>
            <p class="text-sm opacity-70">Fetch HTTP simple sans JavaScript (1-2 secondes)</p>
          </div>
        </div>
      </label>

      <label class="card card-bordered cursor-pointer p-4 <%= scraped_url.use_browser == true ? 'border-info bg-info/10' : '' %>">
        <div class="flex items-start gap-3">
          <%= f.radio_button :use_browser, true, class: "radio radio-info mt-1" %>
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="font-bold">Playwright</span>
              <span class="badge badge-info badge-sm">Complet</span>
            </div>
            <p class="text-sm opacity-70">Browser Chromium headless avec JavaScript (5-10 secondes)</p>
          </div>
        </div>
      </label>
    </div>
  </div>

  <div>
    <%= f.label :commentaire, "Commentaire (notes personnelles)", class: "label font-bold" %>
    <%= f.text_area :commentaire, class: "textarea textarea-bordered w-full", rows: 4, placeholder: "Notes personnelles..." %>
  </div>

  <div>
    <%= f.label :click_selector, "Clic à exécuter avant parsing (Playwright uniquement)", class: "label font-bold" %>
    <%= f.text_field :click_selector, class: "input input-bordered w-full", placeholder: 'Ex: a:has-text("Voir tous les événements")' %>
    <p class="text-sm opacity-60 mt-1">
      Sélecteur CSS/Playwright d'un bouton à cliquer après le chargement de la page
      pour révéler du contenu masqué. Laisser vide si non applicable.
    </p>
  </div>

  <div class="card bg-base-200 p-4">
    <h3 class="font-bold mb-2">Enrichissement via pages détail</h3>
    <label class="flex items-center gap-2 cursor-pointer mb-2">
      <%= f.check_box :enrich_detail_pages, class: "checkbox checkbox-primary" %>
      <span>Visiter les pages détail de chaque événement</span>
    </label>
    <p class="text-sm opacity-60 mb-3">
      Utile pour les sites qui cachent les heures/tarifs sur les pages individuelles
      (ex. HelloAsso). Ralentit le scraping (jusqu'à 20 pages supplémentaires).
    </p>

    <%= f.label :detail_link_selector, "Sélecteur des liens vers pages détail", class: "label font-bold" %>
    <%= f.text_field :detail_link_selector, class: "input input-bordered w-full", placeholder: 'Ex: a[href*="/evenements/"]' %>
    <p class="text-sm opacity-60 mt-1">
      Sélecteur CSS des liens <code>&lt;a href="..."&gt;</code> qui pointent vers les pages détail à visiter.
    </p>
  </div>

  <div>
    <%= f.label :notes_correctrices, "Notes correctrices (pour Claude)", class: "label font-bold" %>
    <%= f.text_area :notes_correctrices, class: "textarea textarea-bordered w-full font-mono", rows: 10, placeholder: "Instructions pour corriger les erreurs de parsing..." %>
  </div>

  <div class="flex gap-4">
    <%= f.submit "Enregistrer", class: "btn btn-primary" %>
    <%= link_to "Annuler", @scraped_url.persisted? ? admin_scraped_url_path(@scraped_url) : admin_scraped_urls_path, class: "btn btn-ghost" %>
  </div>
<% end %>
