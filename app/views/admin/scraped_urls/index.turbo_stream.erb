<%= turbo_stream.append "admin-scraped-urls-tbody" do %>
  <% @scraped_urls.each do |url| %>
    <tr class="hover">
      <td>
        <%= link_to admin_scraped_url_path(url), class: "link link-primary", data: { turbo_frame: "_top" } do %>
          <div class="font-medium"><%= url.nom.presence || url.url.truncate(40) %></div>
          <% if url.nom.present? %>
            <div class="text-xs opacity-50"><%= url.url.truncate(50) %></div>
          <% end %>
        <% end %>
      </td>
      <td class="text-sm"><%= url.professors.map(&:nom).join(", ").presence || "—" %></td>
      <td>
        <% if url.use_browser %>
          <span class="badge badge-info badge-sm">Playwright</span>
        <% else %>
          <span class="badge badge-success badge-sm">HTTParty</span>
        <% end %>
      </td>
      <td><span class="badge badge-sm <%= url.statut_scraping == 'actif' ? 'badge-success' : 'badge-ghost' %>"><%= url.statut_scraping %></span></td>
      <td class="text-sm opacity-60"><%= url.updated_at.strftime("%d/%m/%Y %H:%M") %></td>
      <td class="text-right space-x-1">
        <%= link_to "Voir", admin_scraped_url_path(url), class: "btn btn-ghost btn-xs", data: { turbo_frame: "_top" } %>
        <%= link_to "Modifier", edit_admin_scraped_url_path(url), class: "btn btn-ghost btn-xs", data: { turbo_frame: "_top" } %>
        <%= button_to "Scraper", scrape_now_admin_scraped_url_path(url), method: :post, class: "btn btn-success btn-xs", data: { turbo_frame: "_top" } %>
      </td>
    </tr>
  <% end %>
<% end %>

<%# Replace the current page frame with the next one (removes old spinner) %>
<%= turbo_stream.replace "admin-scraped-urls-page-#{params[:page]}" do %>
  <% if @pagy.next %>
    <%= turbo_frame_tag "admin-scraped-urls-page-#{@pagy.next}",
                        src: admin_scraped_urls_path(page: @pagy.next, format: :turbo_stream),
                        loading: :lazy do %>
      <div class="text-center py-8">
        <span class="loading loading-spinner loading-md text-primary"></span>
      </div>
    <% end %>
  <% end %>
<% end %>
