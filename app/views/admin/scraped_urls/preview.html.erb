<div class="mb-6 flex justify-between items-center">
  <div>
    <%= link_to "← Retour", admin_scraped_url_path(@scraped_url), class: "text-terracotta hover:underline" %>
  </div>
  <div class="flex gap-3 items-center">
    <!-- Badge indicateur mode production -->
    <% if @scraped_url.use_browser %>
      <span class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm font-medium"
            title="Mode production : Playwright (browser complet avec JavaScript)">
        🎭 Playwright
      </span>
    <% else %>
      <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium"
            title="Mode production : HTTParty (fetch rapide sans JavaScript)">
        🌐 HTTParty
      </span>
    <% end %>

    <!-- Bouton HTTParty -->
    <%= button_to "🌐 HTTParty", fetch_with_httparty_admin_scraped_url_path(@scraped_url),
                  method: :post,
                  class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700",
                  title: "Fetch rapide sans JavaScript\n\n📋 QUAND L'UTILISER :\n• Sites statiques (HTML/CSS simple)\n• Pas de contenu chargé en JavaScript\n• Pas de React/Vue/Angular\n\n⏱️ DURÉE : ~1-2 secondes\n\n💡 AVANTAGE : Rapide et léger\n\n⚠️ LIMITE : Ne voit pas le contenu JS dynamique",
                  data: { confirm: "Télécharger le HTML avec HTTParty ?\n\n⚡ Rapide (1-2s)\n❌ N'exécute PAS le JavaScript" },
                  form: { class: "inline" } %>

    <!-- Bouton Playwright -->
    <%= button_to "🎭 Playwright", fetch_with_playwright_admin_scraped_url_path(@scraped_url),
                  method: :post,
                  class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700",
                  title: "Lance un vrai browser Chromium headless\n\n📋 QUAND L'UTILISER :\n• Sites Wix, Squarespace, Webflow\n• Applications React/Vue/Angular\n• Contenu chargé en JavaScript\n• Calendriers dynamiques\n• Lazy-loading d'images\n\n⏱️ DURÉE : ~5-10 secondes\n\n💡 AVANTAGE : Voit TOUT le contenu (comme un vrai navigateur)\n\n⚠️ COÛT : Plus lent et consomme plus de ressources",
                  data: { confirm: "Télécharger le HTML avec Playwright ?\n\n🎭 Lance un vrai browser Chromium\n✅ Exécute le JavaScript\n⏱️ Plus lent (5-10s)" },
                  form: { class: "inline" } %>

    <!-- Bouton Markdown maker -->
    <%= button_to "📝 Markdown maker", generate_markdown_admin_scraped_url_path(@scraped_url),
                  method: :post,
                  class: "bg-moutarde text-white px-4 py-2 rounded hover:bg-moutarde-dark",
                  title: "Convertit le HTML en cache → Markdown + data-attributes\n\n📋 FONCTION :\n• Nettoie le HTML (retire scripts, styles, nav)\n• Extrait les data-attributes\n• Convertit en Markdown optimisé\n\n⏱️ DURÉE : Instantané (<1s)\n\n💡 USAGE : Tester la conversion HTML→Markdown sans re-télécharger",
                  data: { confirm: "Générer le Markdown à partir du HTML en cache ?" },
                  form: { class: "inline" } %>

    <!-- Bouton Re-parser avec Claude -->
    <%= link_to "🔄 Re-parser avec Claude", preview_admin_scraped_url_path(@scraped_url, force_parse: true),
                class: "bg-terracotta text-white px-4 py-2 rounded hover:bg-terracotta-dark",
                title: "Envoie le Markdown à Claude pour extraire les événements\n\n📋 FONCTION :\n• Utilise le Markdown en cache (pas de re-download)\n• Applique les notes correctrices\n• Parse avec Claude CLI\n• Crée/update les Events en base\n\n⏱️ DURÉE : ~30-60 secondes\n\n💡 USAGE : Tester différentes notes correctrices sans re-scraper",
                data: { confirm: "Re-parser avec Claude prendra ~30-60 secondes. Continuer ?" } %>
  </div>
</div>

<h1 class="text-3xl font-bold mb-6">
  Preview Scraping - <%= @scraped_url.nom || @scraped_url.url %>
  <% if params[:force_parse] == "true" %>
    <span class="text-sm text-gray-500">(Re-parsing en cours...)</span>
  <% end %>
</h1>

<% if @error %>
  <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded mb-6">
    <strong>Erreur:</strong> <%= @error %>
  </div>
<% else %>
  <!-- Stats summary -->
  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-xl font-bold mb-4">Résumé</h2>
    <div class="grid grid-cols-3 gap-4">
      <div>
        <div class="text-sm text-gray-600">HTML brut</div>
        <div class="text-2xl font-bold"><%= number_to_human_size(@scraped_url.derniere_version_html&.bytesize || 0) %></div>
        <% if @scraped_url.derniere_version_html.present? %>
          <div class="text-xs text-gray-500 mt-1">
            Mis à jour : <%= time_ago_in_words(@scraped_url.updated_at) %>
          </div>
        <% end %>
      </div>
      <div>
        <div class="text-sm text-gray-600">Markdown</div>
        <div class="text-2xl font-bold"><%= number_to_human_size(@scraped_url.derniere_version_markdown&.bytesize || 0) %></div>
        <% if @scraped_url.derniere_version_markdown.present? %>
          <div class="text-xs text-gray-500 mt-1">
            Mis à jour : <%= time_ago_in_words(@scraped_url.updated_at) %>
          </div>
        <% end %>
      </div>
      <div>
        <div class="text-sm text-gray-600">Réduction</div>
        <% if @scraped_url.derniere_version_html.present? && @scraped_url.derniere_version_markdown.present? %>
          <% reduction = ((1 - @scraped_url.derniere_version_markdown.bytesize.to_f / @scraped_url.derniere_version_html.bytesize) * 100).round(1) %>
          <div class="text-2xl font-bold text-green-600"><%= reduction %>%</div>
        <% else %>
          <div class="text-2xl font-bold text-gray-400">—</div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="bg-white rounded-lg shadow">
    <!-- Tab headers -->
    <div class="border-b border-gray-200">
      <nav class="flex -mb-px">
        <button onclick="showTab('parsed')" id="tab-parsed" class="tab-button active px-6 py-3 border-b-2 border-terracotta text-terracotta font-medium">
          Résultat parsing
        </button>
        <button onclick="showTab('markdown-view')" id="tab-markdown-view" class="tab-button px-6 py-3 border-b-2 border-transparent text-gray-600 hover:text-gray-800 hover:border-gray-300">
          Markdown view
        </button>
        <button onclick="showTab('markdown')" id="tab-markdown" class="tab-button px-6 py-3 border-b-2 border-transparent text-gray-600 hover:text-gray-800 hover:border-gray-300">
          Markdown brut
        </button>
        <button onclick="showTab('data')" id="tab-data" class="tab-button px-6 py-3 border-b-2 border-transparent text-gray-600 hover:text-gray-800 hover:border-gray-300">
          Data attributes
        </button>
        <button onclick="showTab('html-view')" id="tab-html-view" class="tab-button px-6 py-3 border-b-2 border-transparent text-gray-600 hover:text-gray-800 hover:border-gray-300">
          HTML view
        </button>
        <button onclick="showTab('html')" id="tab-html" class="tab-button px-6 py-3 border-b-2 border-transparent text-gray-600 hover:text-gray-800 hover:border-gray-300">
          HTML brut
        </button>
      </nav>
    </div>

    <!-- Tab contents -->
    <div class="p-6">
      <!-- Parsed results tab -->
      <div id="content-parsed" class="tab-content">
        <% if params[:force_parse] != "true" %>
          <div class="bg-blue-50 border border-blue-200 text-blue-800 px-4 py-3 rounded mb-4">
            ℹ️ <strong>Données en cache</strong> - Événements déjà en base de données.
            Cliquez sur "Re-parser avec Claude" pour forcer une nouvelle analyse.
            <% last_event = @scraped_url.events.order(updated_at: :desc).first %>
            <% if last_event %>
              <br>
              <span class="text-xs">Dernier parsing réussi : <%= time_ago_in_words(last_event.updated_at) %></span>
            <% end %>
          </div>
        <% end %>

        <% if @parse_result[:error] %>
          <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded">
            <%= @parse_result[:error] %>
          </div>
        <% else %>
          <div class="prose max-w-none">
            <h3 class="text-lg font-bold mb-2">Événements détectés: <%= @parse_result[:events]&.size || 0 %></h3>
            <pre class="bg-gray-50 p-4 rounded overflow-x-auto text-sm"><%= JSON.pretty_generate(@parse_result) %></pre>
          </div>
        <% end %>
      </div>

      <!-- Markdown view tab (rendered) -->
      <div id="content-markdown-view" class="tab-content hidden">
        <% if @scraped_url.derniere_version_markdown.present? %>
          <div class="prose max-w-none bg-white p-6 rounded border border-gray-200">
            <%= render_markdown(@scraped_url.derniere_version_markdown) %>
          </div>
        <% else %>
          <div class="text-gray-500 italic">Aucun Markdown disponible. Lancez un scraping pour générer le Markdown.</div>
        <% end %>
      </div>

      <!-- Markdown brut tab -->
      <div id="content-markdown" class="tab-content hidden">
        <% if @scraped_url.derniere_version_markdown.present? %>
          <pre class="bg-gray-50 p-4 rounded overflow-x-auto text-sm whitespace-pre-wrap"><%= @scraped_url.derniere_version_markdown %></pre>
        <% else %>
          <div class="text-gray-500 italic">Aucun Markdown disponible. Lancez un scraping pour générer le Markdown.</div>
        <% end %>
      </div>

      <!-- Data attributes tab -->
      <div id="content-data" class="tab-content hidden">
        <% if @scraped_url.data_attributes.present? && @scraped_url.data_attributes.any? %>
          <pre class="bg-gray-50 p-4 rounded overflow-x-auto text-sm"><%= JSON.pretty_generate(@scraped_url.data_attributes) %></pre>
        <% else %>
          <div class="text-gray-500 italic">Aucune data-attribute détectée dans le HTML.</div>
        <% end %>
      </div>

      <!-- HTML view tab (rendered) -->
      <div id="content-html-view" class="tab-content hidden">
        <% if @html.present? %>
          <div class="mb-4 text-sm text-gray-600">
            ⚠️ Rendu du HTML scrapé dans un iframe isolé (CSS et JS chargés depuis les URLs originales)
          </div>
          <iframe
            src="<%= raw_html_admin_scraped_url_path(@scraped_url) %>"
            class="w-full border border-gray-300 rounded"
            style="min-height: 800px;"
            sandbox="allow-same-origin allow-scripts"
          ></iframe>
        <% else %>
          <div class="text-gray-500 italic">Aucun HTML disponible.</div>
        <% end %>
      </div>

      <!-- HTML tab (source code) -->
      <div id="content-html" class="tab-content hidden">
        <% if @html.present? %>
          <pre class="bg-gray-50 p-4 rounded overflow-x-auto text-xs"><%= @html %></pre>
        <% else %>
          <div class="text-gray-500 italic">Aucun HTML disponible.</div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<script>
  function showTab(tabName) {
    // Hide all tab contents
    document.querySelectorAll('.tab-content').forEach(el => {
      el.classList.add('hidden');
    });

    // Remove active class from all buttons
    document.querySelectorAll('.tab-button').forEach(el => {
      el.classList.remove('active', 'border-terracotta', 'text-terracotta');
      el.classList.add('border-transparent', 'text-gray-600');
    });

    // Show selected tab content
    document.getElementById('content-' + tabName).classList.remove('hidden');

    // Add active class to selected button
    const activeButton = document.getElementById('tab-' + tabName);
    activeButton.classList.add('active', 'border-terracotta', 'text-terracotta');
    activeButton.classList.remove('border-transparent', 'text-gray-600');
  }
</script>
