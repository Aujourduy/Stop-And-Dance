<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-3xl font-bold">Notifications</h1>
    <% if @non_lu_count > 0 %>
      <span class="badge badge-error"><%= @non_lu_count %> non lue(s)</span>
    <% end %>
  </div>
</div>

<%# Filtres %>
<div class="flex flex-wrap gap-2 mb-4">
  <%= link_to "Toutes", admin_notifications_path, class: "btn btn-sm #{params[:status].nil? && params[:category].nil? ? 'btn-primary' : 'btn-ghost'}" %>
  <%= link_to "Non lues", admin_notifications_path(status: "non_lu"), class: "btn btn-sm #{params[:status] == 'non_lu' ? 'btn-primary' : 'btn-ghost'}" %>
  <%= link_to "Erreurs", admin_notifications_path(category: "error"), class: "btn btn-sm #{params[:category] == 'error' ? 'btn-error' : 'btn-ghost'}" %>
  <%= link_to "Warnings", admin_notifications_path(category: "warning"), class: "btn btn-sm #{params[:category] == 'warning' ? 'btn-warning' : 'btn-ghost'}" %>
  <%= link_to "Récurrence", admin_notifications_path(category: "recurrence"), class: "btn btn-sm #{params[:category] == 'recurrence' ? 'btn-secondary' : 'btn-ghost'}" %>
  <%= link_to "Archivées", admin_notifications_path(status: "archive"), class: "btn btn-sm #{params[:status] == 'archive' ? 'btn-ghost btn-active' : 'btn-ghost'}" %>

  <%= form_with url: admin_notifications_path, method: :get, class: "flex gap-2 items-center ml-auto" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "Rechercher...", class: "input input-bordered input-sm w-40" %>
    <%= f.submit "Ok", class: "btn btn-primary btn-sm" %>
  <% end %>
</div>

<%= turbo_frame_tag "admin-notifications-list", data: { controller: "infinite-scroll" } do %>
  <% if @notifications.any? %>
    <%= form_with url: bulk_update_admin_notifications_path, method: :post, class: "space-y-2" do |f| %>
      <div class="flex gap-2 mb-2">
        <button type="submit" name="status" value="lu" class="btn btn-ghost btn-xs">Marquer lu</button>
        <button type="submit" name="status" value="archive" class="btn btn-ghost btn-xs">Archiver</button>
      </div>

      <div class="overflow-x-auto">
        <table class="table">
          <thead>
            <tr>
              <th><input type="checkbox" class="checkbox checkbox-sm" onclick="document.querySelectorAll('input[name=\'ids[]\']').forEach(c => c.checked = this.checked)"></th>
              <th>Catégorie</th>
              <th>Status</th>
              <th>Titre</th>
              <th>Source</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="admin-notifications-tbody">
            <% @notifications.each do |notif| %>
              <%= render "notification_row", notif: notif %>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  <% else %>
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body text-center opacity-50">
        <p>Aucune notification</p>
      </div>
    </div>
  <% end %>

  <% if @pagy.next %>
    <%= turbo_frame_tag "admin-notifications-page-#{@pagy.next}",
                        src: admin_notifications_path(page: @pagy.next, status: params[:status], category: params[:category], q: params[:q], format: :turbo_stream),
                        loading: :lazy do %>
      <div class="text-center py-8">
        <span class="loading loading-spinner loading-md text-primary"></span>
      </div>
    <% end %>
  <% end %>
<% end %>
