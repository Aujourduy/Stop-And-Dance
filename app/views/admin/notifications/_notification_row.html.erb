<%# locals: notif %>
<tr class="hover <%= 'font-bold' if notif.status == 'non_lu' %>">
  <td><input type="checkbox" name="ids[]" value="<%= notif.id %>" class="checkbox checkbox-sm"></td>
  <td>
    <span class="badge badge-sm
      <%= case notif.category
          when 'error' then 'badge-error'
          when 'warning' then 'badge-warning'
          when 'recurrence' then 'badge-secondary'
          when 'scraping' then 'badge-info'
          when 'crawl' then 'badge-accent'
          else 'badge-ghost'
          end %>">
      <%= notif.category %>
    </span>
  </td>
  <td>
    <span class="badge badge-sm
      <%= case notif.status
          when 'non_lu' then 'badge-error'
          when 'lu' then 'badge-ghost'
          when 'valide' then 'badge-success'
          when 'archive' then 'badge-ghost opacity-50'
          end %>">
      <%= notif.status %>
    </span>
  </td>
  <td>
    <div><%= notif.title %></div>
    <% if notif.message.present? %>
      <div class="text-xs opacity-60 truncate max-w-md"><%= notif.message.truncate(100) %></div>
    <% end %>
  </td>
  <td class="text-sm opacity-60"><%= notif.source %></td>
  <td class="text-sm opacity-60"><%= notif.created_at.strftime("%d/%m %H:%M") %></td>
  <td class="space-x-1">
    <% if notif.status == "non_lu" %>
      <%= button_to "Lu", admin_notification_path(notif, status: "lu"), method: :patch, class: "btn btn-ghost btn-xs", data: { turbo_frame: "_top" } %>
    <% end %>
    <% if notif.status != "valide" %>
      <%= button_to "Validé", admin_notification_path(notif, status: "valide"), method: :patch, class: "btn btn-success btn-xs", data: { turbo_frame: "_top" } %>
    <% end %>
    <% if notif.status != "archive" %>
      <%= button_to "Archiver", admin_notification_path(notif, status: "archive"), method: :patch, class: "btn btn-ghost btn-xs", data: { turbo_frame: "_top" } %>
    <% end %>
  </td>
</tr>
