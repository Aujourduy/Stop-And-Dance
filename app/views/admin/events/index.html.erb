<h1 class="text-3xl font-bold mb-6">Événements</h1>

<div class="card bg-base-100 shadow-sm mb-6">
  <div class="card-body p-4">
    <%= form_with url: admin_events_path, method: :get, class: "grid grid-cols-1 md:grid-cols-3 gap-4" do |f| %>
      <div>
        <%= f.label :professor_id, "Professeur", class: "label font-bold" %>
        <%= f.select :professor_id,
                     options_from_collection_for_select(@professors, :id, :nom, params[:professor_id]),
                     { include_blank: "Tous les professeurs" },
                     class: "select select-bordered w-full" %>
      </div>
      <div>
        <%= f.label :titre, "Recherche titre", class: "label font-bold" %>
        <%= f.text_field :titre, value: params[:titre], placeholder: "Ex: Stage Paris", class: "input input-bordered w-full" %>
      </div>
      <div class="flex items-end gap-2">
        <%= f.submit "Filtrer", class: "btn btn-primary btn-sm" %>
        <%= link_to "Réinitialiser", admin_events_path, class: "btn btn-ghost btn-sm" %>
      </div>
      <%= f.hidden_field :sort, value: params[:sort] %>
    <% end %>
  </div>
</div>

<% if @filtered || @sorted %>
  <p class="mb-4 opacity-60"><%= @events.count %> événement(s) trouvé(s)</p>
<% end %>

<%= turbo_frame_tag "admin-events-list", data: (@pagy.present? ? { controller: "infinite-scroll" } : {}) do %>
  <div class="overflow-x-auto">
    <table class="table">
      <thead>
        <tr>
          <th>
            <%= link_to admin_events_path(sort: (params[:sort] == "titre_asc" ? "titre_desc" : "titre_asc"), professor_id: params[:professor_id], titre: params[:titre]), class: "link link-hover" do %>
              Titre <%= "↑" if params[:sort] == "titre_asc" %><%= "↓" if params[:sort] == "titre_desc" %>
            <% end %>
          </th>
          <th>
            <%= link_to admin_events_path(sort: (params[:sort] == "date_asc" ? "date_desc" : "date_asc"), professor_id: params[:professor_id], titre: params[:titre]), class: "link link-hover" do %>
              Date <%= "↑" if params[:sort] == "date_asc" %><%= "↓" if params[:sort] == "date_desc" %>
            <% end %>
          </th>
          <th>
            <%= link_to admin_events_path(sort: (params[:sort] == "professor_asc" ? "professor_desc" : "professor_asc"), professor_id: params[:professor_id], titre: params[:titre]), class: "link link-hover" do %>
              Professeur <%= "↑" if params[:sort] == "professor_asc" %><%= "↓" if params[:sort] == "professor_desc" %>
            <% end %>
          </th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @events.each do |event| %>
          <tr class="hover">
            <td><%= link_to event.titre, admin_event_path(event), class: "link link-primary", data: { turbo_frame: "_top" } %></td>
            <td class="text-sm"><%= event.date_debut.strftime("%d/%m/%Y") %></td>
            <td class="text-sm"><%= event.display_professors.presence || event.professor&.nom %></td>
            <td class="text-right">
              <%= link_to "Modifier", edit_admin_event_path(event), class: "btn btn-ghost btn-xs", data: { turbo_frame: "_top" } %>
              <%= button_to "Supprimer",
                            admin_event_path(event),
                            method: :delete,
                            form: { data: { turbo_confirm: "Supprimer définitivement « #{event.titre} » ?" }, turbo_frame: "_top" },
                            class: "btn btn-ghost btn-xs text-error" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @pagy&.next %>
    <%= turbo_frame_tag "admin-events-page-#{@pagy.next}",
                        src: admin_events_path(page: @pagy.next, format: :turbo_stream, sort: params[:sort], professor_id: params[:professor_id], titre: params[:titre]),
                        loading: :lazy do %>
      <div class="text-center py-8">
        <span class="loading loading-spinner loading-md text-primary"></span>
      </div>
    <% end %>
  <% end %>
<% end %>
