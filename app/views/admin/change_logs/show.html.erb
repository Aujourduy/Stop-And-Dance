<div class="mb-6">
  <%= link_to "← Retour", admin_change_logs_path, class: "text-terracotta hover:underline" %>
</div>

<div class="bg-white rounded-lg shadow p-6 mb-6">
  <h1 class="text-2xl font-bold mb-4">Détails du changement</h1>

  <dl class="space-y-3 mb-6">
    <div>
      <dt class="font-bold text-gray-700">Date/heure</dt>
      <dd class="text-gray-900"><%= @change_log.created_at.strftime("%d/%m/%Y à %H:%M:%S") %></dd>
    </div>

    <div>
      <dt class="font-bold text-gray-700">Source</dt>
      <dd class="text-gray-900">
        <%= link_to @change_log.scraped_url.nom || @change_log.scraped_url.url,
                    admin_scraped_url_path(@change_log.scraped_url),
                    class: "text-terracotta hover:underline" %>
      </dd>
    </div>

    <div>
      <dt class="font-bold text-gray-700">Changements</dt>
      <dd class="text-gray-900">
        <span class="text-green-600"><%= @change_log.changements_detectes['lines_added'] %> lignes ajoutées</span>,
        <span class="text-red-600"><%= @change_log.changements_detectes['lines_removed'] %> lignes supprimées</span>
      </dd>
    </div>
  </dl>

  <div>
    <h2 class="text-xl font-bold mb-3">Diff HTML</h2>
    <div class="bg-gray-50 p-4 rounded border border-gray-200 overflow-x-auto">
      <%= raw @change_log.diff_html %>
    </div>
  </div>
</div>
