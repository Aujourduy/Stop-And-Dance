<div class="mb-6">
  <%= link_to "← Retour", admin_change_logs_path, class: "link link-primary" %>
</div>

<div class="card bg-base-100 shadow-sm mb-6">
  <div class="card-body">
    <h1 class="card-title text-2xl mb-4">Détails du changement</h1>

    <dl class="space-y-3 mb-6">
      <div>
        <dt class="font-bold">Date/heure</dt>
        <dd><%= @change_log.created_at.strftime("%d/%m/%Y à %H:%M:%S") %></dd>
      </div>
      <div>
        <dt class="font-bold">Source</dt>
        <dd>
          <%= link_to @change_log.scraped_url.nom || @change_log.scraped_url.url,
                      admin_scraped_url_path(@change_log.scraped_url),
                      class: "link link-primary" %>
        </dd>
      </div>
      <div>
        <dt class="font-bold">Changements</dt>
        <dd>
          <span class="text-success">+<%= @change_log.changements_detectes['lines_added'] %> lignes</span>,
          <span class="text-error">-<%= @change_log.changements_detectes['lines_removed'] %> lignes</span>
        </dd>
      </div>
    </dl>

    <div>
      <h2 class="text-xl font-bold mb-3">Diff HTML</h2>
      <div class="bg-base-200 p-4 rounded-box overflow-x-auto">
        <%= raw @change_log.diff_html %>
      </div>
    </div>
  </div>
</div>
