<h1 class="text-3xl font-bold mb-6">Logs de Changements</h1>

<%= turbo_frame_tag "admin-change-logs-list", data: { controller: "infinite-scroll" } do %>
  <div class="overflow-x-auto">
    <table class="table">
      <thead>
        <tr>
          <th>Date</th>
          <th>URL</th>
          <th>Changement</th>
        </tr>
      </thead>
      <tbody>
        <% @change_logs.each do |log| %>
          <tr class="hover">
            <td class="text-sm"><%= log.created_at.strftime("%d/%m/%Y %H:%M") %></td>
            <td class="text-sm">
              <%= link_to log.scraped_url.url.truncate(40), admin_scraped_url_path(log.scraped_url), class: "link link-primary", data: { turbo_frame: "_top" } %>
            </td>
            <td class="text-sm">
              <span class="text-error">-<%= log.changements_detectes["lines_removed"] || 0 %></span>
              /
              <span class="text-success">+<%= log.changements_detectes["lines_added"] || 0 %></span>
              lignes
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @pagy.next %>
    <%= turbo_frame_tag "admin-change-logs-page-#{@pagy.next}",
                        src: admin_change_logs_path(page: @pagy.next, format: :turbo_stream),
                        loading: :lazy do %>
      <div class="text-center py-8">
        <span class="loading loading-spinner loading-md text-primary"></span>
      </div>
    <% end %>
  <% end %>
<% end %>
