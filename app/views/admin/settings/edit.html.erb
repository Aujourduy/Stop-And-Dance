<h1 class="text-3xl font-bold mb-6">Paramètres globaux</h1>

<div class="card bg-base-100 shadow-sm">
  <div class="card-body">
    <%= form_with model: @setting, url: admin_settings_path, method: :patch, class: "space-y-6" do |f| %>
      <div>
        <%= f.label :claude_global_instructions, "Consignes globales pour Claude (toutes les URLs)", class: "label font-bold" %>
        <%= f.text_area :claude_global_instructions,
                        class: "textarea textarea-bordered w-full font-mono",
                        rows: 15,
                        placeholder: "Exemple:\n- Toujours extraire les dates au format ISO 8601\n- Si le prix n'est pas mentionné, mettre null" %>
        <p class="text-sm opacity-60 mt-2">
          Ces consignes sont envoyées à Claude pour <strong>toutes les URLs scrapées</strong>.<br>
          Les "Notes correctrices" spécifiques à chaque URL sont ajoutées en plus.
        </p>
      </div>

      <div>
        <%= f.label :openrouter_default_model, "Modèle OpenRouter par défaut (crawler site)", class: "label font-bold" %>
        <%= f.select :openrouter_default_model, options_for_select([
          ["Gemma 3n 4B (free)", "google/gemma-3n-e4b-it:free"],
          ["Gemma 3 12B (free)", "google/gemma-3-12b-it:free"],
          ["Gemma 3 27B (free)", "google/gemma-3-27b-it:free"],
          ["Llama 3.3 70B (free)", "meta-llama/llama-3.3-70b-instruct:free"]
        ], @setting.openrouter_default_model), {}, class: "select select-bordered w-full" %>
        <p class="text-sm opacity-60 mt-2">
          Modèle utilisé par défaut pour classifier les pages lors du crawl de site.<br>
          Peut être overridé au moment du lancement de chaque crawl.
        </p>
      </div>

      <div class="flex gap-4">
        <%= f.submit "Enregistrer", class: "btn btn-primary" %>
        <%= link_to "Retour", admin_root_path, class: "btn btn-ghost" %>
      </div>
    <% end %>
  </div>
</div>
