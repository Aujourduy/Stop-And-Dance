<!DOCTYPE html>
<html>
  <head>
    <%= display_meta_tags %>
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Stop & Dance">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag "logo/favicon.ico", rel: "icon", type: "image/x-icon" %>
    <%= favicon_link_tag "logo/favicon.svg", rel: "icon", type: "image/svg+xml" %>
    <%= favicon_link_tag "logo/favicon-96x96.png", rel: "icon", type: "image/png", sizes: "96x96" %>
    <%= favicon_link_tag "logo/apple-touch-icon.png", rel: "apple-touch-icon" %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Shrikhand&display=swap" rel="stylesheet">
    <%= javascript_importmap_tags %>

    <%# Plausible Analytics (self-hosted) — tracking automatique des pages publiques %>
    <% if Rails.env.production? %>
      <script defer data-domain="stopand.dance" src="https://stats.stopand.dance/js/script.js"></script>
    <% end %>
  </head>

  <body class="bg-base-100" data-theme="stopanddance" <%= "data-controller=debug-design" if Rails.env.development? %>>
    <%# Debug Design Mode (Development only) %>
    <% if Rails.env.development? %>
      <div data-debug-design-target="banner" class="hidden fixed top-0 left-0 right-0 bg-red-600 text-white text-center py-2 font-bold" style="z-index: 2147483647;">
        MODE DEBUG DESIGN - Appuyez sur Ctrl+Shift+D pour désactiver
      </div>
      <div data-debug-design-target="tooltip" class="hidden fixed p-4 rounded-lg shadow-2xl pointer-events-none" style="left: 50%; top: 50%; transform: translate(-50%, -50%); background-color: #93C572; color: #1A1A1A; min-width: 320px; max-width: 400px; z-index: 2147483647;">
      </div>
    <% end %>

    <%# Skip to main content link (accessibility) %>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 bg-terracotta text-white px-4 py-2 rounded">
      Skip to main content
    </a>

    <%= render 'shared/navbar' %>
    <%= render 'shared/mobile_drawer' %>

    <%# Flash messages %>
    <% if flash.any? %>
      <div class="container mx-auto px-4 mt-4">
        <% flash.each do |type, message| %>
          <div role="alert" class="alert <%= type == 'alert' ? 'alert-error' : 'alert-success' %> mb-4">
            <span><%= message %></span>
          </div>
        <% end %>
      </div>
    <% end %>

    <main id="main">
      <%= yield %>
    </main>

    <%= render 'shared/footer' %>
    <%= render 'shared/scroll_top' %>
  </body>
</html>
