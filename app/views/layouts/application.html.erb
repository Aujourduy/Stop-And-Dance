<!DOCTYPE html>
<html>
  <head>
    <%= display_meta_tags %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="3 Graces">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-beige" <%= "data-controller=debug-design" if Rails.env.development? %>>
    <%# Debug Design Mode (Development only) %>
    <% if Rails.env.development? %>
      <div data-debug-design-target="banner" class="hidden fixed top-0 left-0 right-0 bg-red-600 text-white text-center py-2 font-bold" style="z-index: 2147483647;">
        MODE DEBUG DESIGN - Appuyez sur Ctrl+Shift+D pour désactiver
      </div>
      <div data-debug-design-target="tooltip" class="hidden fixed p-4 rounded-lg shadow-2xl pointer-events-none" style="left: 50%; top: 50%; transform: translate(-50%, -50%); background-color: #93C572; color: #1A1A1A; min-width: 320px; max-width: 400px; z-index: 2147483647;">
      </div>
    <% end %>

    <%# Skip to main content link (accessibility) %>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 bg-terracotta text-white px-4 py-2 rounded">
      Skip to main content
    </a>

    <%= render 'shared/navbar' %>
    <%= render 'shared/mobile_drawer' %>

    <%# Flash messages %>
    <% if flash.any? %>
      <div class="container mx-auto px-4 mt-4">
        <% flash.each do |type, message| %>
          <div class="<%= type == 'alert' ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800' %> px-4 py-3 rounded mb-4">
            <%= message %>
          </div>
        <% end %>
      </div>
    <% end %>

    <main id="main">
      <%= yield %>
    </main>

    <%= render 'shared/footer' %>
  </body>
</html>
