<!DOCTYPE html>
<html>
  <head>
    <title>Admin - Stop & Dance</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= display_meta_tags %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100">
    <%# Admin navbar %>
    <nav class="bg-dark-bg text-white py-4 mb-8">
      <div class="container mx-auto px-4">
        <div class="flex items-center justify-between">
          <h1 class="text-xl font-bold">Admin - Stop & Dance</h1>
          <div class="flex items-center gap-6">
            <%= link_to "URLs", admin_scraped_urls_path, class: "hover:text-terracotta" %>
            <%= link_to "Professeurs", admin_professors_path, class: "hover:text-terracotta" %>
            <%= link_to "Événements", admin_events_path, class: "hover:text-terracotta" %>
            <%= link_to "Changements", admin_change_logs_path, class: "hover:text-terracotta" %>
            <%= link_to "Paramètres", edit_admin_settings_path, class: "hover:text-terracotta" %>
            <%= link_to "← Site public", root_path, class: "hover:text-terracotta" %>
          </div>
        </div>
      </div>
    </nav>

    <main class="container mx-auto px-4 pb-12">
      <%# Flash messages %>
      <% if flash.any? %>
        <% flash.each do |type, message| %>
          <div class="<%= type == 'alert' ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800' %> px-4 py-3 rounded mb-4 flash-message"
               data-controller="flash"
               data-flash-type-value="<%= type %>">
            <%= message %>
            <button type="button"
                    class="float-right text-2xl leading-none font-semibold opacity-50 hover:opacity-100"
                    onclick="this.parentElement.remove()">
              ×
            </button>
          </div>
        <% end %>
      <% end %>

      <%= yield %>
    </main>

    <script>
      // Auto-dismiss flash messages after 5 seconds
      document.addEventListener('turbo:load', function() {
        document.querySelectorAll('.flash-message').forEach(function(flash) {
          setTimeout(function() {
            flash.style.transition = 'opacity 0.5s';
            flash.style.opacity = '0';
            setTimeout(function() {
              flash.remove();
            }, 500);
          }, 5000);
        });
      });
    </script>
  </body>
</html>
