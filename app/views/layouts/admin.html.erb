<!DOCTYPE html>
<html>
  <head>
    <title>Admin - Stop & Dance</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= display_meta_tags %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-base-200" data-theme="stopanddance">
    <%# Admin navbar %>
    <nav class="navbar bg-neutral text-neutral-content mb-8">
      <div class="navbar-start">
        <h1 class="text-xl font-bold">Admin - Stop & Dance</h1>
      </div>
      <div class="navbar-end flex-wrap gap-2">
        <%= link_to "URLs", admin_scraped_urls_path, class: "btn btn-ghost btn-sm" %>
        <%= link_to "Professeurs", admin_professors_path, class: "btn btn-ghost btn-sm" %>
        <%= link_to "Événements", admin_events_path, class: "btn btn-ghost btn-sm" %>
        <%= link_to "Changements", admin_change_logs_path, class: "btn btn-ghost btn-sm" %>
        <%= link_to "Jobs", admin_jobs_path, class: "btn btn-ghost btn-sm" %>
        <% notif_count = AdminNotification.non_lu.count %>
        <%= link_to admin_notifications_path, class: "btn btn-ghost btn-sm" do %>
          Notifications
          <% if notif_count > 0 %>
            <span class="badge badge-error badge-xs"><%= notif_count %></span>
          <% end %>
        <% end %>
        <%= link_to "Paramètres", edit_admin_settings_path, class: "btn btn-ghost btn-sm" %>
        <%= link_to "📊 Stats", "https://stats.stopand.dance/stopand.dance",
                    target: "_blank", rel: "noopener",
                    class: "btn btn-ghost btn-sm",
                    title: "Dashboard Plausible Analytics" %>
        <%= link_to "← Site public", root_path, class: "btn btn-ghost btn-sm" %>
      </div>
    </nav>

    <main class="container mx-auto px-4 pb-12">
      <%# Flash messages %>
      <% if flash.any? %>
        <% flash.each do |type, message| %>
          <div role="alert" class="alert <%= type == 'alert' ? 'alert-error' : 'alert-success' %> mb-4 flash-message"
               data-controller="flash"
               data-flash-type-value="<%= type %>">
            <span><%= message %></span>
            <button type="button" class="btn btn-ghost btn-sm" onclick="this.parentElement.remove()">×</button>
          </div>
        <% end %>
      <% end %>

      <%= yield %>
    </main>

    <script>
      document.addEventListener('turbo:load', function() {
        document.querySelectorAll('.flash-message').forEach(function(flash) {
          setTimeout(function() {
            flash.style.transition = 'opacity 0.5s';
            flash.style.opacity = '0';
            setTimeout(function() { flash.remove(); }, 500);
          }, 5000);
        });
      });
    </script>
  </body>
</html>
