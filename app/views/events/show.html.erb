<%= turbo_frame_tag "event_modal" do %>
  <%# Modal overlay %>
  <div class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4"
       data-controller="modal"
       data-action="click->modal#close">

    <%# Modal panel %>
    <div data-debug-id="event-modal" class="card bg-base-100 max-w-2xl w-full max-h-[90vh] overflow-y-auto"
         data-modal-target="panel"
         data-action="click->modal#stopPropagation">

      <%# Close button %>
      <%= link_to evenements_path,
                  class: "btn btn-ghost btn-sm absolute top-4 right-4 text-2xl",
                  data: { turbo_frame: "_top" } do %>
        &times;
      <% end %>

      <div class="card-body">
        <%# Badges %>
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="badge badge-primary"><%= @event.type_event_humanized %></span>
          <% if @event.gratuit %>
            <span class="badge badge-success">Gratuit</span>
          <% end %>
          <% if @event.en_ligne %>
            <span class="badge badge-info">En ligne</span>
          <% end %>
          <% if @event.en_presentiel %>
            <span class="badge badge-outline">Présentiel</span>
          <% end %>
        </div>

        <%# Photo %>
        <% if @event.photo_url.present? %>
          <figure class="mb-4">
            <%= image_tag @event.photo_url, alt: @event.titre, class: "w-full h-64 object-cover rounded-box" %>
          </figure>
        <% end %>

        <%# Title %>
        <h2 class="card-title font-script italic text-3xl mb-4"><%= @event.titre %></h2>

        <%# Info block %>
        <div class="space-y-3 mb-6">
          <div><span class="font-medium">Avec :</span> <%= [@event.professor.prenom, @event.professor.nom].compact.join(" ") %></div>
          <div>
            <span class="font-medium">Date :</span>
            <%= l(@event.date_debut_date, format: :long) %>
            <% if @event.date_fin_date != @event.date_debut_date %>
              → <%= l(@event.date_fin_date, format: :long) %>
            <% end %>
          </div>
          <% if @event.horaire_connu? %>
            <div>
              <span class="font-medium">Horaire :</span>
              <%= @event.display_heure_debut %> — <%= @event.display_heure_fin %>
              (<%= @event.display_duree %>)
            </div>
          <% else %>
            <div class="text-sm opacity-60 italic">Horaires à confirmer sur le site source</div>
          <% end %>
          <div>
            <span class="font-medium">Lieu :</span> <%= @event.lieu %><br>
            <span class="text-sm opacity-60"><%= @event.adresse_complete %></span>
          </div>
          <div>
            <span class="font-medium">Tarif :</span>
            <% if @event.gratuit %>
              <span class="text-success font-medium">Gratuit</span>
            <% elsif @event.prix_reduit.present? %>
              <%= number_to_currency(@event.prix_normal, unit: "€", format: "%n%u") %>/<%= number_to_currency(@event.prix_reduit, unit: "€", format: "%n%u") %>
            <% else %>
              <%= number_to_currency(@event.prix_normal, unit: "€", format: "%n%u") %>
            <% end %>
          </div>

          <div class="flex flex-wrap gap-2 mt-2">
            <% if @event.scraped_url.present? %>
              <%# brakeman:disable LinkToHref %>
              <%= link_to "Voir la page source →",
                          @event.scraped_url.url,
                          target: "_blank",
                          rel: "noopener noreferrer",
                          class: "btn btn-primary btn-sm" %>
            <% end %>
            <% if @event.professor.site_web.present? && @event.professor.site_web != @event.scraped_url&.url %>
              <%= link_to "Site de #{@event.professor.prenom || @event.professor.nom} →",
                          @event.professor.site_web,
                          target: "_blank",
                          rel: "noopener noreferrer",
                          class: "btn btn-outline btn-primary btn-sm" %>
            <% end %>
          </div>
        </div>

        <%# Description %>
        <div class="divider"></div>
        <h3 class="text-primary font-bold text-xl mb-3">Description</h3>
        <div class="prose max-w-none">
          <%= simple_format(@event.description) %>
        </div>

        <%# Tags %>
        <% if @event.tags.present? %>
          <div class="divider"></div>
          <h3 class="text-primary font-bold text-xl mb-3">Pratiques</h3>
          <div class="flex flex-wrap gap-2">
            <% @event.tags.each do |tag| %>
              <span class="badge badge-outline"><%= tag %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
