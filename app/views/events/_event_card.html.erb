<%# locals: event %>
<%= link_to evenement_path(event.slug),
            class: "card card-side bg-base-100 mb-0 rounded-none lg:rounded-box overflow-hidden items-start",
            data: { turbo_frame: "event_modal", debug_id: "event-card-#{event.id}" } do %>

  <%# Avatar %>
  <figure class="flex-shrink-0 p-2 sm:p-4 pb-0 lg:pb-4">
    <% photo = event.photo_url.presence || event.professor&.avatar_url %>
    <% if photo.present? %>
      <%= image_tag photo,
                    alt: event.titre,
                    class: "w-24 h-24 sm:w-32 sm:h-32 object-cover rounded",
                    loading: "lazy" %>
    <% else %>
      <div class="w-24 h-24 sm:w-32 sm:h-32 bg-primary/30 rounded flex items-center justify-center text-primary-content text-2xl sm:text-4xl">
        <%= event.professor.nom&.first&.upcase || "?" %>
      </div>
    <% end %>
  </figure>

  <div class="card-body p-2 sm:p-4 gap-0.5 min-w-0">
    <%# Horaire + Badges %>
    <div class="flex flex-wrap items-center gap-1 sm:gap-2">
      <span class="text-primary font-bold text-base sm:text-lg">
        <%= event.horaire_connu? ? event.display_heure_debut : "—" %>
      </span>
      <span class="badge badge-primary badge-sm"><%= event.type_event_humanized %></span>
      <% if event.en_ligne %>
        <span class="badge badge-info badge-sm">En ligne</span>
      <% end %>
      <% if event.en_presentiel %>
        <span class="badge badge-outline badge-sm">Présentiel</span>
      <% end %>
    </div>

    <%# Titre %>
    <h3 class="card-title text-base sm:text-lg truncate"><%= event.titre %></h3>

    <%# Avec prof %>
    <p class="opacity-60 truncate" style="font-size: 0.96rem;">
      Avec <%= [event.professor&.prenom, event.professor&.nom].compact.join(" ") %>
    </p>

    <%# Lieu + Prix %>
    <div class="flex flex-wrap items-center justify-between gap-1">
      <p class="opacity-60 flex items-center gap-1 truncate" style="font-size: 0.96rem;">
        <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
        </svg>
        <span class="truncate"><%= event.lieu %></span>
      </p>
      <p class="font-medium text-sm whitespace-nowrap">
        <% if event.gratuit %>
          <span class="text-success">Gratuit</span>
        <% elsif event.prix_reduit.present? %>
          <%= number_to_currency(event.prix_normal, unit: "€", format: "%n%u") %>/<%= number_to_currency(event.prix_reduit, unit: "€", format: "%n%u") %>
        <% else %>
          <%= number_to_currency(event.prix_normal, unit: "€", format: "%n%u") %>
        <% end %>
      </p>
    </div>
  </div>
<% end %>
