<div class="container mx-auto px-0 lg:px-4 py-8" data-controller="mobile-filters">
  <%# Mobile filter pill — sticky en haut, isolé dans un turbo-frame pour MAJ au filtrage %>
  <%= turbo_frame_tag "filter-pill" do %>
    <%= render "filter_pill" %>
  <% end %>

  <%# Mobile filter overlay (hidden by default) %>
  <div data-mobile-filters-target="overlay"
       class="hidden fixed inset-0 bg-black/50 z-50 lg:hidden"
       data-action="click->mobile-filters#close">
  </div>

  <aside data-mobile-filters-target="panel"
         class="hidden fixed top-0 right-0 h-full w-80 bg-white z-50 overflow-y-auto transform transition-transform lg:hidden filter-overlay">
    <%= render "shared/filters" %>
  </aside>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_350px] gap-8">
    <%# Main column: Event list (70% on desktop) %>
    <div>
      <%= turbo_frame_tag "events-list", data: { controller: "infinite-scroll" } do %>
        <h1 class="text-3xl font-script italic mb-8 px-4 lg:px-0">
          <%= @filtered ? "Agenda filtré" : "Agenda complet" %> : Ateliers (<%= @atelier_count %>) et Stages (<%= @stage_count %>)
        </h1>

        <%= render "events_list", events: @events %>

        <%# Infinite scroll trigger %>
        <% if @pagy.next %>
          <%= turbo_frame_tag "page-#{@pagy.next}",
                              src: evenements_path(page: @pagy.next, format: :turbo_stream),
                              loading: :lazy do %>
            <div class="text-center py-8">
              <span class="loading loading-spinner loading-md text-primary"></span>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <%# Right sidebar: Filters (30% on desktop, hidden on mobile) %>
    <aside class="hidden lg:block">
      <%= render "shared/filters" %>
      <%= render "shared/newsletter_signup" %>
    </aside>
  </div>
</div>

<%# Modal container for event details (Turbo Frame) %>
<%= turbo_frame_tag "event_modal" %>
