<div class="min-h-screen bg-dark-bg p-8">
  <div class="max-w-4xl mx-auto space-y-8">

    <!-- Title with custom font -->
    <h1 class="font-script italic text-terracotta text-5xl">
      Stop & Dance
    </h1>

    <!-- Color palette test -->
    <section class="space-y-4">
      <h2 class="text-white text-2xl font-sans font-semibold">Color Palette Test</h2>

      <div class="grid grid-cols-3 gap-4">
        <div class="bg-terracotta text-white p-4 rounded-lg">
          <p class="font-medium">Terracotta</p>
          <p class="text-sm opacity-80">#C2623F</p>
        </div>
        <div class="bg-terracotta-light text-white p-4 rounded-lg">
          <p class="font-medium">Terracotta Light</p>
          <p class="text-sm opacity-80">#D97E5C</p>
        </div>
        <div class="bg-terracotta-dark text-white p-4 rounded-lg">
          <p class="font-medium">Terracotta Dark</p>
          <p class="text-sm opacity-80">#A5502F</p>
        </div>
        <div class="bg-beige text-dark-bg p-4 rounded-lg">
          <p class="font-medium">Beige</p>
          <p class="text-sm opacity-80">#F5E6D3</p>
        </div>
        <div class="bg-beige-dark text-dark-bg p-4 rounded-lg">
          <p class="font-medium">Beige Dark</p>
          <p class="text-sm opacity-80">#E8D4BB</p>
        </div>
        <div class="bg-white text-dark-bg p-4 rounded-lg border border-beige">
          <p class="font-medium">White (default)</p>
          <p class="text-sm opacity-80">#FFFFFF</p>
        </div>
      </div>
    </section>

    <!-- Button component test -->
    <section class="space-y-4">
      <h2 class="text-white text-2xl font-sans font-semibold">Button Component Test</h2>
      <button class="btn-primary">AGENDA</button>
      <button class="btn-primary">FILTRER</button>
    </section>

    <!-- Responsive layout test -->
    <section class="space-y-4">
      <h2 class="text-white text-2xl font-sans font-semibold">Responsive Layout Test</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-beige p-6 rounded-lg">
          <p class="text-dark-bg">Full width on mobile</p>
          <p class="text-dark-bg">1/2 on tablet (md)</p>
          <p class="text-dark-bg">1/3 on desktop (lg)</p>
        </div>
        <div class="bg-beige p-6 rounded-lg">
          <p class="text-dark-bg">Column 2</p>
        </div>
        <div class="bg-beige p-6 rounded-lg">
          <p class="text-dark-bg">Column 3</p>
        </div>
      </div>
    </section>

    <!-- Font family test -->
    <section class="space-y-4">
      <h2 class="text-white text-2xl font-sans font-semibold">Font Family Test</h2>
      <p class="font-script italic text-terracotta text-3xl">Georgia serif italic (script)</p>
      <p class="font-sans text-white text-lg">Inter sans-serif (body text)</p>
    </section>

    <!-- Tag component test -->
    <section class="space-y-4">
      <h2 class="text-white text-2xl font-sans font-semibold">Tag Component Test</h2>
      <div class="flex flex-wrap gap-3">
        <%= render 'shared/tag', text: 'Atelier', variant: 'atelier' %>
        <%= render 'shared/tag', text: 'Stage', variant: 'stage' %>
        <%= render 'shared/tag', text: 'Gratuit', variant: 'gratuit' %>
        <%= render 'shared/tag', text: 'En ligne', variant: 'en_ligne' %>
        <%= render 'shared/tag', text: 'En présentiel', variant: 'en_presentiel' %>
        <%= render 'shared/tag', text: 'Default', variant: 'unknown' %>
      </div>
    </section>

  </div>
</div>
